{
  "schemaVersion": "attestor.production-rehearsal.manifest.v1",
  "rehearsalId": "v0.2-production-rehearsal-template",
  "targetEnvironment": {
    "name": "replace-with-target-name",
    "type": "production-like",
    "provider": "gke",
    "region": "replace-with-region",
    "cluster": "replace-with-cluster",
    "namespace": "attestor",
    "publicHostname": "replace-with-hostname",
    "owner": "replace-with-operator"
  },
  "source": {
    "repository": "AI-gateway-systems/attestor",
    "commit": "0000000",
    "tag": "v0.3.0-evaluation",
    "release": "v0.3.0-evaluation",
    "workflowRuns": {
      "evaluationSmoke": "replace-with-run-id",
      "fullVerify": "replace-with-run-id",
      "releaseProvenance": "replace-with-run-id",
      "productionRehearsal": "pending"
    }
  },
  "runtime": {
    "profile": "production-shared",
    "requireSharedAuthority": true,
    "noLocalFallback": true,
    "releaseAuthorityPgUrlRef": "external-secret:ATTESTOR_RELEASE_AUTHORITY_PG_URL",
    "redisUrlRef": "external-secret:REDIS_URL"
  },
  "secretPosture": {
    "mode": "external-secret",
    "plaintextSecretsAllowed": false,
    "redactedFields": [
      "ATTESTOR_RELEASE_AUTHORITY_PG_URL",
      "ATTESTOR_CONTROL_PLANE_PG_URL",
      "ATTESTOR_BILLING_LEDGER_PG_URL",
      "REDIS_URL",
      "STRIPE_API_KEY",
      "STRIPE_WEBHOOK_SECRET",
      "ATTESTOR_ADMIN_API_KEY",
      "ATTESTOR_METRICS_API_KEY"
    ]
  },
