{
  "openapi": "3.2.0",
  "info": {
    "title": "Attestor Action Authorization API",
    "version": "0.2.0-evaluation",
    "summary": "Bounded hosted API contract for AI action authorization before consequence.",
    "description": "This evaluation contract describes the generic admission route and the shadow-mode read surfaces that exist today. It is not a production readiness claim, a compliance certification, or a wallet/custody API."
  },
  "servers": [
    {
      "url": "{baseUrl}",
      "description": "Customer-operated or hosted Attestor base URL.",
      "variables": {
        "baseUrl": {
          "default": "http://localhost:3000"
        }
      }
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Admissions",
      "description": "Authorize proposed AI actions before downstream consequence."
    },
    {
      "name": "Shadow",
      "description": "Read-only shadow-mode visibility, policy discovery, audit evidence, and dashboard surfaces."
    }
  ],
  "paths": {
    "/api/v1/admissions": {
      "post": {
        "tags": [
          "Admissions"
        ],
        "operationId": "createAdmission",
        "summary": "Evaluate one proposed AI action.",
        "description": "Returns an admission envelope with `admit`, `narrow`, `review`, or `block` semantics. Non-enforcing modes observe or warn; enforcing modes can hold or block before downstream execution.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GenericAdmissionRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Admission evaluated.",
            "headers": {
              "Cache-Control": {
                "$ref": "#/components/headers/NoStore"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GenericAdmissionEnvelope"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/FailClosedProblem"
          },
          "503": {
            "$ref": "#/components/responses/FailClosedProblem"
          }
        }
      }
    },
    "/api/v1/shadow/summary": {
      "get": {
        "tags": [
          "Shadow"
        ],
        "operationId": "getShadowSummary",
        "summary": "Summarize shadow admission events.",
        "responses": {
          "200": {
            "description": "Data-minimized shadow summary for the current tenant.",
            "headers": {
              "Cache-Control": {
                "$ref": "#/components/headers/NoStore"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ShadowSummaryResponse"
                }
              }
            }
          },
          "503": {
            "$ref": "#/components/responses/FailClosedProblem"
          }
        }
      }
    },
    "/api/v1/shadow/recommendations": {
      "get": {
        "tags": [
          "Shadow"
        ],
        "operationId": "getShadowRecommendations",
        "summary": "Read compact shadow recommendations.",
        "responses": {
          "200": {
            "description": "Recommendation list derived from the latest shadow simulation.",
            "headers": {
              "Cache-Control": {
                "$ref": "#/components/headers/NoStore"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ShadowRecommendationsResponse"
                }
              }
            }
          },
          "503": {
            "$ref": "#/components/responses/FailClosedProblem"
          }
        }
      }
    },
    "/api/v1/shadow/action-risk-inventory": {
      "get": {
        "tags": [
          "Shadow"
        ],
        "operationId": "getActionRiskInventory",
        "summary": "List discovered action-risk surfaces.",
        "responses": {
          "200": {
            "description": "Data-minimized inventory of action surfaces and control gaps.",
            "headers": {
              "Cache-Control": {
                "$ref": "#/components/headers/NoStore"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ActionRiskInventoryResponse"
                }
              }
            }
          },
          "503": {
            "$ref": "#/components/responses/FailClosedProblem"
          }
        }
      }
    },
    "/api/v1/shadow/policy-candidates": {
      "get": {
        "tags": [
          "Shadow"
        ],
        "operationId": "getPolicyCandidates",
        "summary": "Read draft policy candidates.",
        "description": "Candidates are recommendations requiring customer approval. This route never activates policy and never auto-enforces.",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 50
            },
            "description": "Maximum number of candidates to return."
          },
          {
            "name": "cursor",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Offset cursor returned by the previous page."
          }
        ],
        "responses": {
          "200": {
            "description": "Approval-required policy candidate bundle.",
            "headers": {
              "Cache-Control": {
                "$ref": "#/components/headers/NoStore"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PolicyCandidatesResponse"
                }
              }
            }
          },
          "503": {
            "$ref": "#/components/responses/FailClosedProblem"
          }
        }
      }
    },
    "/api/v1/shadow/audit-evidence": {
      "get": {
        "tags": [
          "Shadow"
        ],
        "operationId": "getAuditEvidence",
        "summary": "Read the canonical audit evidence packet.",
        "description": "Returns reviewer evidence for shadow-to-enforcement review. It is not a compliance certificate.",
        "responses": {
          "200": {
            "description": "Canonical audit evidence export for the current tenant.",
            "headers": {
              "Cache-Control": {
                "$ref": "#/components/headers/NoStore"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuditEvidenceResponse"
                }
              }
            }
          },
          "503": {
            "$ref": "#/components/responses/FailClosedProblem"
          }
        }
      }
    },
    "/api/v1/shadow/business-risk-dashboard": {
      "get": {
        "tags": [
          "Shadow"
        ],
        "operationId": "getBusinessRiskDashboard",
        "summary": "Read the operator-facing business risk dashboard.",
        "description": "Returns decision-support metrics over audit evidence. It does not infer financial impact and does not authorize consequences.",
        "responses": {
          "200": {
            "description": "Business risk dashboard model for the current tenant.",
            "headers": {
              "Cache-Control": {
                "$ref": "#/components/headers/NoStore"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BusinessRiskDashboardResponse"
                }
              }
            }
          },
          "503": {
            "$ref": "#/components/responses/FailClosedProblem"
          }
        }
      }
    },
    "/api/v1/shadow/dashboard-summary": {
      "get": {
        "tags": [
          "Shadow"
        ],
        "operationId": "getDashboardSummary",
        "summary": "Read the compact first-screen dashboard API summary.",
        "description": "Returns a data-minimized decision-support summary over audit evidence and the business-risk dashboard. It does not expose raw payloads and does not authorize consequences.",
        "responses": {
          "200": {
            "description": "Dashboard API summary model for the current tenant.",
            "headers": {
              "Cache-Control": {
                "$ref": "#/components/headers/NoStore"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DashboardApiSummaryResponse"
                }
              }
            }
          },
          "503": {
            "$ref": "#/components/responses/FailClosedProblem"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Tenant API key or authenticated bearer credential. Credentials must be sent in the Authorization header, not in URLs."
      }
    },
    "headers": {
      "NoStore": {
        "description": "Shadow and admission responses are not cacheable.",
        "schema": {
          "type": "string",
          "const": "no-store"
        }
      }
    },
    "responses": {
      "FailClosedProblem": {
        "description": "RFC 9457-style problem detail with Attestor fail-closed fields.",
        "headers": {
          "Cache-Control": {
            "$ref": "#/components/headers/NoStore"
          }
        },
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/FailClosedProblem"
            }
          }
        }
      }
    },
    "schemas": {
      "GenericAdmissionRequest": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "mode",
          "actor",
          "action",
          "domain",
          "downstreamSystem"
        ],
        "properties": {
          "mode": {
            "$ref": "#/components/schemas/AdmissionMode"
          },
          "actor": {
            "type": "string",
            "minLength": 1
          },
          "action": {
            "type": "string",
            "minLength": 1
          },
          "domain": {
            "$ref": "#/components/schemas/ConsequenceDomain"
          },
          "downstreamSystem": {
            "type": "string",
            "minLength": 1
          },
          "policyRef": {
            "type": [
              "string",
              "null"
            ]
          },
          "evidenceRefs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "authoritySources": {
            "type": "array",
            "description": "Structured authority-source references for the untrusted-content authority guard. Untrusted content, tool output, retrieved content, and model summaries cannot authorize a consequence or self-promote into trusted authority.",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "sourceKind",
                "claimKind",
                "sourceRef"
              ],
              "properties": {
                "sourceKind": {
                  "type": "string",
                  "enum": [
                    "user-prompt",
                    "customer-email",
                    "external-document",
                    "web-page",
                    "chat-message",
                    "ticket-comment",
                    "tool-output",
                    "llm-summary",
                    "retrieved-content",
                    "verified-approval",
                    "approval-workflow",
                    "customer-policy",
                    "idp-directory",
                    "authority-record",
                    "manual-review",
                    "signed-evidence",
                    "provider-record",
                    "system-config"
                  ]
                },
                "claimKind": {
                  "type": "string",
                  "enum": [
                    "authorization",
                    "approval",
                    "policy",
                    "evidence",
                    "context",
                    "instruction"
                  ]
                },
                "sourceRef": {
                  "type": "string",
                  "minLength": 1,
                  "description": "Opaque reference only. Raw customer or private source material must not be included."
                },
                "trustClass": {
                  "type": "string",
                  "enum": [
                    "untrusted-content",
                    "model-generated",
                    "trusted-authority",
                    "trusted-evidence",
                    "trusted-system-context"
                  ]
                },
                "evidenceDigest": {
                  "type": "string",
                  "description": "Digest of the authority evidence for trusted authority sources."
                }
              }
            }
          },
          "approvals": {
            "type": "array",
            "description": "Digest-only approval provenance claims. Required when approval is used as authority; raw approval text, raw customer messages, and model summaries must not be included.",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "approvalRef",
                "sourceKind"
              ],
              "properties": {
                "approvalRef": {
                  "type": "string",
                  "minLength": 1,
                  "description": "Opaque approval reference only."
                },
                "sourceKind": {
                  "type": "string",
                  "enum": [
                    "chat-message",
                    "customer-email",
                    "ticket-comment",
                    "user-prompt",
                    "external-document",
                    "tool-output",
                    "llm-summary",
                    "approval-workflow",
                    "reviewer-queue",
                    "manual-review",
                    "signed-approval",
                    "idp-directory",
                    "policy-control-plane"
                  ]
                },
                "state": {
                  "type": "string",
                  "enum": [
                    "approved",
                    "pending",
                    "rejected",
                    "revoked"
                  ]
                },
                "sourceRef": {
                  "type": "string",
                  "description": "Opaque source-system reference only."
                },
                "reviewerRef": {
                  "type": "string",
                  "description": "Opaque reviewer identity reference."
                },
                "reviewerAuthorityDigest": {
                  "type": "string"
                },
                "approvalDigest": {
                  "type": "string"
                },
                "scopeDigest": {
                  "type": "string"
                },
                "issuedAt": {
                  "type": "string",
                  "format": "date-time"
                },
                "expiresAt": {
                  "type": "string",
                  "format": "date-time"
                },
                "trustClass": {
                  "type": "string",
                  "enum": [
                    "untrusted-content",
                    "model-generated",
                    "unverified-tool-output",
                    "verified-workflow",
                    "verified-reviewer",
                    "signed-authority",
                    "system-authority"
                  ]
                },
                "signatureVerified": {
                  "type": "boolean"
                },
                "stepUpVerified": {
                  "type": "boolean"
                }
              }
            }
          },
          "allowedToolResultEvidenceClasses": {
            "type": "array",
            "description": "Evidence classes the integration allows tool results to support. This is a contract allowlist, not a grant of tool authority.",
            "items": {
              "type": "string",
              "enum": [
                "payment-record",
                "identity-record",
                "policy-record",
                "approval-record",
                "ticket-record",
                "document-record",
                "telemetry-record",
                "security-state",
                "unknown"
              ]
            }
          },
          "toolResults": {
            "type": "array",
            "description": "Structured, digest-only tool-result provenance for the tool-result poisoning guard. Raw tool payloads, raw results, prompts, private records, and provider bodies must not be included.",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "toolResultRef",
                "toolKind",
                "sourceTrustClass",
                "resultUse"
              ],
              "properties": {
                "toolResultRef": {
                  "type": "string",
                  "minLength": 1,
                  "description": "Opaque tool-result reference only."
                },
                "toolKind": {
                  "type": "string",
                  "enum": [
                    "web-search",
                    "file-search",
                    "mcp-tool",
                    "database-query",
                    "provider-api",
                    "browser",
                    "email-parser",
                    "ticketing-system",
                    "custom"
                  ]
                },
                "sourceTrustClass": {
                  "type": "string",
                  "enum": [
                    "untrusted-external",
                    "model-generated",
                    "customer-controlled",
                    "provider-authoritative",
                    "system-authoritative",
                    "signed-attestation"
                  ]
                },
                "resultUse": {
                  "type": "string",
                  "enum": [
                    "authority",
                    "policy",
                    "evidence",
                    "instruction",
                    "context",
                    "review-summary"
                  ]
                },
                "sourceRef": {
                  "type": "string",
                  "description": "Opaque source reference only."
                },
                "sourceTimestamp": {
                  "type": "string",
                  "format": "date-time"
                },
                "integrityDigest": {
                  "type": "string",
                  "description": "Digest binding the tool output observed by the trusted adapter."
                },
                "evidenceDigest": {
                  "type": "string",
                  "description": "Digest binding the evidence material represented by the tool result."
                },
                "evidenceClass": {
                  "type": "string",
                  "enum": [
                    "payment-record",
                    "identity-record",
                    "policy-record",
                    "approval-record",
                    "ticket-record",
                    "document-record",
                    "telemetry-record",
                    "security-state",
                    "unknown"
                  ]
                },
                "allowedEvidenceClasses": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "enum": [
                      "payment-record",
                      "identity-record",
                      "policy-record",
                      "approval-record",
                      "ticket-record",
                      "document-record",
                      "telemetry-record",
                      "security-state",
                      "unknown"
                    ]
                  }
                },
                "signatureVerified": {
                  "type": "boolean",
                  "description": "Trusted-adapter assertion only. The generic hosted route does not expose signed-attestation PKI verification input in this slice."
                },
                "toolRisk": {
                  "type": "string",
                  "enum": [
                    "low",
                    "medium",
                    "high",
                    "critical"
                  ]
                }
              }
            }
          },
          "noGoLedgerRef": {
            "type": [
              "string",
              "null"
            ],
            "description": "Opaque reference to the customer or operator no-go condition ledger. Raw hold records or case contents must not be included."
          },
          "noGoConditions": {
            "type": "array",
            "description": "Digest-first no-go hold records for the no-go condition ledger guard. Active holds and natural-language bypass attempts block generic admission; raw case details must not be returned.",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "conditionRef",
                "kind",
                "state",
                "sourceKind"
              ],
              "properties": {
                "conditionRef": {
                  "type": "string",
                  "minLength": 1,
                  "description": "Opaque hold reference only."
                },
                "kind": {
                  "type": "string",
                  "enum": [
                    "fraud-hold",
                    "legal-hold",
                    "compliance-hold",
                    "security-hold",
                    "privacy-hold",
                    "risk-hold",
                    "production-freeze",
                    "customer-defined-hold"
                  ]
                },
                "state": {
                  "type": "string",
                  "enum": [
                    "active",
                    "pending-review",
                    "released",
                    "expired"
                  ]
                },
                "sourceKind": {
                  "type": "string",
                  "enum": [
                    "policy-control-plane",
                    "fraud-system",
                    "legal-system",
                    "compliance-system",
                    "security-system",
                    "privacy-system",
                    "risk-owner",
                    "customer-admin",
                    "chat-message",
                    "customer-email",
                    "llm-summary",
                    "tool-output"
                  ]
                },
                "sourceRef": {
                  "type": "string",
                  "description": "Opaque source reference only."
                },
                "ownerRef": {
                  "type": "string",
                  "description": "Opaque hold owner reference only."
                },
                "ownerAuthorityDigest": {
                  "type": "string"
                },
                "scopeDigest": {
                  "type": "string"
                },
                "issuedAt": {
                  "type": "string"
                },
                "expiresAt": {
                  "type": "string"
                },
                "releaseDigest": {
                  "type": "string"
                }
              }
            }
          },
          "noGoNaturalLanguageBypassAttempted": {
            "type": [
              "boolean",
              "null"
            ],
            "description": "Operator/customer-attested bypass flag for no-go hold attempts."
          },
          "noGoNaturalLanguageSignals": {
            "type": "array",
            "description": "Optional text signals scanned only to produce bypass digests. Raw signal text must not be returned in admission responses or shadow reads.",
            "items": {
              "type": "string"
            }
          },
          "noGoBypassAttemptRef": {
            "type": [
              "string",
              "null"
            ],
            "description": "Opaque reference to the bypass attempt review material."
          },
          "observedFeatures": {
            "type": "object",
            "additionalProperties": {
              "type": [
                "string",
                "number",
                "boolean",
                "null"
              ]
            },
            "description": "Upstream or operator-derived feature observations. Positive readiness observations cannot satisfy adapter-readiness without a matching trusted observedFeatureOrigins entry."
          },
          "observedFeatureOrigins": {
            "type": "object",
            "additionalProperties": {
              "type": "string",
              "enum": [
                "caller-supplied",
                "operator-attested",
                "customer-gateway",
                "attestor-runtime",
                "trusted-adapter"
              ]
            },
            "description": "Origin marker for observedFeatures. Only operator-attested, customer-gateway, attestor-runtime, and trusted-adapter origins can satisfy positive adapter-readiness."
          },
          "amount": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "value": {
                "type": "number"
              },
              "currency": {
                "type": "string"
              }
            }
          },
          "recipient": {
            "type": [
              "string",
              "null"
            ],
            "description": "Accepted as input, but raw recipient values must not be returned by shadow read routes."
          }
        }
      },
      "AdmissionMode": {
        "type": "string",
        "enum": [
          "observe",
          "warn",
          "review",
          "enforce"
        ]
      },
      "ConsequenceDomain": {
        "type": "string",
        "enum": [
          "money-movement",
          "data-disclosure",
          "authority-change",
          "external-communication",
          "regulated-filing",
          "system-operation",
          "programmable-money",
          "decision-support",
          "custom"
        ]
      },
      "AdmissionDecision": {
        "type": "string",
        "enum": [
          "admit",
          "narrow",
          "review",
          "block"
        ]
      },
      "GenericAdmissionEnvelope": {
        "type": "object",
        "required": [
          "mode",
          "shadowDecision",
          "downstreamPosture",
          "enforcementActive",
          "admission"
        ],
        "properties": {
          "mode": {
            "$ref": "#/components/schemas/AdmissionMode"
          },
          "shadowDecision": {
            "type": "string"
          },
          "downstreamPosture": {
            "type": "string"
          },
          "enforcementActive": {
            "type": "boolean"
          },
          "admission": {
            "$ref": "#/components/schemas/AdmissionResponse"
          }
        }
      },
      "AdmissionResponse": {
        "type": "object",
        "required": [
          "decision",
          "allowed",
          "failClosed",
          "reasonCodes",
          "feedback",
          "digest"
        ],
        "properties": {
          "decision": {
            "$ref": "#/components/schemas/AdmissionDecision"
          },
          "allowed": {
            "type": "boolean"
          },
          "failClosed": {
            "type": "boolean"
          },
          "reasonCodes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "feedback": {
            "$ref": "#/components/schemas/ModelSafeFeedback"
          },
          "digest": {
            "type": "string",
            "pattern": "^sha256:"
          }
        }
      },
      "ModelSafeFeedback": {
        "type": "object",
        "description": "Model-facing feedback is deliberately data-minimized: reason codes, missing field names, evidence kinds, operator-only reasons, and safe instruction only. It is not a raw prompt, raw tool payload, provider body, or downstream execution grant.",
        "required": [
          "safeForModel",
          "reasonCodes",
          "missingFields",
          "requiredEvidenceKinds",
          "operatorOnlyReasonCodes",
          "safeInstruction"
        ],
        "properties": {
          "disclosureLevel": {
            "enum": [
              "minimal",
              "actionable",
              "diagnostic"
            ]
          },
          "safeForModel": {
            "const": true
          },
          "reasonCodes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "missingFields": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "requiredEvidenceKinds": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "operatorOnlyReasonCodes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "safeInstruction": {
            "type": "string"
          }
        }
      },
      "FailClosedProblem": {
        "type": "object",
        "required": [
          "type",
          "title",
          "status",
          "detail",
          "decision",
          "failClosed",
